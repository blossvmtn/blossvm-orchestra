{
  "name": "blossvm-orchestra",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "core:build": "bun run --cwd packages/orchestra-core build",
    "core:test": "bun test --cwd packages/orchestra-core",
    "daemon:dev": "bun run --cwd packages/orchestra-daemon dev",
    "daemon:test": "bun test --cwd packages/orchestra-daemon",
    "cli:dev": "bun run --cwd packages/orchestra-cli dev",
    "cockpit:dev": "bun run --cwd apps/orchestra-cockpit tauri dev",
    "cockpit:web": "bun run --cwd apps/orchestra-cockpit dev",
    "web-legacy:dev": "npm run --prefix apps/orchestra-web-legacy dev",
    "test": "bun run core:test && bun run daemon:test"
  }
}
