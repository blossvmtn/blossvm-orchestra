# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (monorepo-wide)
node_modules
/.pnp
.pnp.js

# rust / tauri
/**/src-tauri/target/
/**/src-tauri/gen/

# vite build output
/**/dist/

# daemon local state (never commit the socket token or local db)
/**/*.sqlite
/**/*.sqlite-journal
/**/daemon.token

# Phase 1 (spec docs/specs/2026-07-18-phase-1-worktree-isolation.md, PATH
# convention): real, locally-created git worktrees — a full nested checkout
# per dispatched lane, including its own .git. Never source, always runtime
# state; can even land inside this repo itself if it's ever registered as
# its own test target.
/.orchestra/
/**/.orchestra/

# testing
/coverage

# database
/prisma/db.sqlite
/prisma/db.sqlite-journal
db.sqlite

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
# do not commit any .env files to git, except for the .env.example file. https://create.t3.gg/en/usage/env-variables#using-environment-variables
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo

# idea files
.idea